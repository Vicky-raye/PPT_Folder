# 火山方舟 API Key（必填）https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=366715bc-6b3b-45cb-bf78-9bb2c84ade0b

# 推理接入点 / 模型 ID，如 doubao-seed-2.0-lite-260215
ARK_MODEL_ID=doubao-seed-2-0-lite-260215

# 可选：方舟 base URL，默认北京
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 本机数据目录（SQLite 与上传文件）
DATA_DIR=./data

# 上传文件最大大小（MB）
UPLOAD_MAX_MB=50
